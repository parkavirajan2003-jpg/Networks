#include<stdio.h>
#include <string.h>
#include <stdlib.h>

// Helper function to print a binary string separated every 8 bits
void printEightBits(char *binaryStr) {
   int i;
    for (i = 0; binaryStr[i] != '\0'; i++) {
        printf("%c", binaryStr[i]);
        if ((i + 1) % 8 == 0 && binaryStr[i + 1] != '\0') {
            printf(" ");
        }
    }
    printf("\n");
}

// Convert ASCII text string to binary string format
void stringToBinary(char *word, char *binary) {
    binary[0] = '\0';
    int i,j;
    for (i = 0; word[i] != '\0'; i++) {
        for (j = 7; j >= 0; j--) {
            if ((word[i] >> j) & 1)
                strcat(binary, "1");
            else
                strcat(binary, "0");
        }
    }
}

// Convert binary string format back to ASCII text string
void binaryToString(char *binary, char *word) {
    int len = strlen(binary);
    int index = 0,i,j;
    for (i = 0; i < len; i += 8) {
        char ch = 0;
        for (j = 0; j < 8; j++) {
            ch = (ch << 1) | (binary[i + j] - '0');
        }
        word[index++] = ch;
    }
    word[index] = '\0';
}

int main() {
    char inputString[100];
    char originalBinary[1000] = {0};
    char stuffedData[1200] = {0};
    char transmittedFrame[1300] = {0};
    char receivedFrame[1300] = {0};
    char extractedPayload[1200] = {0};
    char destuffedData[1000] = {0};
    char recoveredString[100] = {0};
    int i;
    printf("Enter input string: ");
    scanf("%s", inputString);

    // 1. Text to Binary conversion
    stringToBinary(inputString, originalBinary);

    // 2. Bit Stuffing Algorithm (Insert '0' after five consecutive '1's)
    int count = 0, j = 0;
    for (i = 0; originalBinary[i] != '\0'; i++) {
        stuffedData[j++] = originalBinary[i];
        if (originalBinary[i] == '1') {
            count++;
        } else {
            count = 0;
        }
        if (count == 5) {
            stuffedData[j++] = '0';
            count = 0;
        }
    }
    stuffedData[j] = '\0';

    // 3. Encapsulate inside standard Framing Flags (01111110)
    sprintf(transmittedFrame, "01111110%s01111110", stuffedData);

    // Display Sender Outputs
    printf("\n=========== SENDER SIDE ===========\n");
    printf("Original Data (String) : %s\n", inputString);
    printf("Original Data (Binary) : "); printEightBits(originalBinary);
    printf("Stuffed Frame          : "); printEightBits(transmittedFrame);
    printf("Transmitted Frame      : "); printEightBits(transmittedFrame);

    // 4. Error Injection Module
    strcpy(receivedFrame, transmittedFrame);
    int choice;
    printf("\n=========== ERROR SIMULATION ===========\n");
    printf("0. No Error\n1. Single-bit Error\n2. Multiple-bit Error\nEnter Choice: ");
    scanf("%d", &choice);

    int frameLen = strlen(receivedFrame);
    if (choice == 1) {
        int pos;
        printf("Enter bit position to corrupt (0 to %d): ", frameLen - 1);
        scanf("%d", &pos);
        if (pos >= 0 && pos < frameLen) {
            receivedFrame[pos] = (receivedFrame[pos] == '0') ? '1' : '0';
            printf("Single-bit error injected successfully.\n");
        }
    } else if (choice == 2) {
        int numErrors, pos;
        printf("How many bits do you want to corrupt? ");
        scanf("%d", &numErrors);
        for (i = 0; i < numErrors; i++) {
            printf("Enter bit position %d: ", i + 1);
            scanf("%d", &pos);
            if (pos >= 0 && pos < frameLen) {
                receivedFrame[pos] = (receivedFrame[pos] == '0') ? '1' : '0';
            }
        }
        printf("%d-bit errors injected successfully.\n", numErrors);
    } else {
        printf("No errors introduced.\n");
    }

    // 5. Receiver Side Module
    printf("\n=========== RECEIVER SIDE ===========\n");
    printf("Received Frame      : "); printEightBits(receivedFrame);

    // Boundary and flag confirmation check
    if (frameLen >= 16 && strncmp(receivedFrame, "01111110", 8) == 0 && strncmp(&receivedFrame[frameLen - 8], "01111110", 8) == 0) {

        strncpy(extractedPayload, &receivedFrame[8], frameLen - 16);
        extractedPayload[frameLen - 16] = '\0';

        // 6. De-stuffing Logic & Structural Error Checking
        count = 0;
        int k = 0;
        int destuffError = 0;

        for (i = 0; extractedPayload[i] != '\0'; i++) {
            destuffedData[k++] = extractedPayload[i];
            if (extractedPayload[i] == '1') {
                count++;
            } else {
                count = 0;
            }

            if (count == 5) {
                if (extractedPayload[i + 1] == '0') {
                    i++; // Drop/skip stuffed zero bit element
                    count = 0;
                } else if (extractedPayload[i + 1] == '1' || extractedPayload[i + 1] == '\0') {
                    destuffError = 1; // Framing rule violation detected
                }
            }
        }
        destuffedData[k] = '\0';

        // 7. Error Detection Status Report (Fixed for Multiple-bit errors)
        if (destuffError || strcmp(destuffedData, originalBinary) != 0) {
            printf("\nERROR DETECTION STATUS: Error detected! Data contains structural errors so data discarded.\n");
        } else {
            printf("De-stuffed Data     : "); printEightBits(destuffedData);
            binaryToString(destuffedData, recoveredString);
            printf("Recovered Original  : %s\n", recoveredString);
            printf("\nERROR DETECTION STATUS: Data received correctly without errors.\n");
        }
    } else {
        printf("\nERROR DETECTION STATUS: Framing Error! Flag delimiters are corrupted so data discarded.\n");
    }

    return 0;
}
